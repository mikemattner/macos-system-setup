{
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "type": "root",
          "style": "powerline",
          "leading_diamond": "",
          "trailing_diamond": "",
          "background": "#242424",
          "foreground": "#FFBB00",
          "template": "  {{ .UserName }} "
        },
        {
          "background": "#021E31",
          "foreground": "#6BC1FA",
          "options": {
            "style": "folder",
            "max_depth": 2,
            "hide_root_location": true,
            "mapped_locations": {
              "C:\\": "C"
            }
          },
          "style": "powerline",
          "powerline_symbol": "",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#6BC1FA",
          "background": "#033D63",
          "style": "powerline",
          "powerline_symbol": "",
          "template": " {{ .HEAD }} ",
          "type": "git"
        },
        {
          "foreground": "#FAAC05",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}red{{ end }}",
            "{{ if gt .Ahead 0 }}red{{ end }}",
            "{{ if gt .Behind 0 }}green{{ end }}"
          ],
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "github_icon": "\uf408 "
          },
          "style": "plain",
          "template": "{{ if .Working.Changed }}<red> ⚡{{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<yellow> {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }}",
          "type": "git"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}