{
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "#FFFFFF",
          "style": "plain",
          "template": "--- ",
          "type": "text"
        },
        {
          "foreground": "#77E4F7",
          "style": "plain",
          "template": "[",
          "type": "text"
        },
        {
          "foreground": "#77E4F7",
          "options": {
            "style": "folder",
            "max_depth": 2,
            "hide_root_location": true,
            "mapped_locations": {
              "C:\\": "C"
            }
          },
          "style": "plain",
          "template": "{{ .Path }}",
          "type": "path"
        },
        {
          "foreground": "#77E4F7",
          "style": "plain",
          "template": "] ",
          "type": "text"
        },
        {
          "foreground": "#FFE700",
          "style": "plain",
          "template": "❮{{ .HEAD }}",
          "type": "git"
        },
        {
          "foreground": "green",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}red{{ end }}",
            "{{ if gt .Ahead 0 }}red{{ end }}",
            "{{ if gt .Behind 0 }}green{{ end }}"
          ],
          "options": {
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "github_icon": "\uf408 "
          },
          "style": "plain",
          "template": "{{ if .Working.Changed }}<red> ⚡{{ .Working.String }}</>{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<yellow> \uf046 {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }}❯ ",
          "type": "git"
        },
        {
          "foreground": "#FFFFFF",
          "style": "plain",
          "template": "»",
          "type": "text"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "version": 4
}